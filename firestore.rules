rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /photos/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /recipes/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /blog/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /posts/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
