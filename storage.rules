rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /photos/{allPaths=**} {
      allow read: if true;
      allow write, delete: if request.auth != null;
    }

    match /recipes/{allPaths=**} {
      allow read: if true;
      allow write, delete: if request.auth != null;
    }

    match /blog/{allPaths=**} {
      allow read: if true;
      allow write, delete: if request.auth != null;
    }

    match /posts/{allPaths=**} {
      allow read: if true;
      allow write, delete: if request.auth != null;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
